library(edgeR)
library(dplyr)
library(readr)

correr_edgeR <- function(muestras, nombre_condicion_1, nombre_condicion_2) {
  
  #Extraer conteos y crear metadatos
  conteos_subset <- round(conteos_invitro[, muestras])
  grupo <- factor(c(rep(nombre_condicion_1, 3), rep(nombre_condicion_2, 3)), 
                  levels = c(nombre_condicion_1, nombre_condicion_2))
  
  # DGEList de edgeR
  y <- DGEList(counts = conteos_subset, group = grupo)
  
  # Filtrado y Normalización TMM
  keep <- filterByExpr(y)
  y <- y[keep, , keep.lib.sizes = FALSE]
  y <- calcNormFactors(y)
  
  # Diseño del modelo y estimación de dispersión
  design <- model.matrix(~grupo)
  y <- estimateDisp(y, design)
  
  # Ajuste del modelo Quasi-Likelihood (recomendado para RNA-seq)
  fit <- glmQLFit(y, design)
  qlf <- glmQLFTest(fit, coef = 2)
  
  # resultados 
  res_edgeR <- topTags(qlf, n = Inf)$table
  res_edgeR$ID_GO <- rownames(res_edgeR)
  
  # Cruzar con el diccionario de Gallus gallus y clasificar
  res_edgeR <- merge(res_edgeR, diccionario_gallus, by = "ID_GO", all.x = TRUE) %>%
    mutate(Nombre_Limpio = ifelse(is.na(Nombre) | Nombre == "", ID_GO, Nombre)) %>%
    mutate(Regulacion = case_when(
      FDR < 0.05 & logFC > 1 ~ "Sobreexpresado (Supervivencia)",
      FDR < 0.05 & logFC < -1 ~ "Silenciado (Camuflaje)",
      TRUE ~ "No Significativo"
    ))
  
  return(res_edgeR)
}


