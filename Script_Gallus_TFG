#!/usr/bin/env Rscript

#######################################
###### INTELIGENCIA ARTIFICIAL ########
#######################################

###Gallus gallus###


library(dplyr)
library(ggplot2)
library(readr)
library(stringr)

# Cargar los datos
datos_in_vitro <- read_csv("go_sums_gallus_gallus.csv", show_col_types = FALSE)

# LIMPIEZA 
# Eliminamos la primera fila vacía 
datos_limpios <- datos_in_vitro %>% filter(!is.na(id))

# Creamos el Diccionario GO oficial para Gallus gallus
diccionario_gallus <- datos_limpios %>% dplyr::select(ID_GO = id, Nombre = nam, Definicion = def)

# Extraemos los conteos y ELIMINAMOS las columnas TLR3_KO
conteos_invitro <- datos_limpios %>%
  dplyr::select(id, 
                starts_with("DF.1_"), 
                starts_with("DF.1P_"), 
                starts_with("DF.1PC_")) %>%
  # Aseguramos que no se nos cuela nada de TLR3
  dplyr::select(-contains("TLR3"))

# Asignamos el ID de la ruta como nombre de fila y quitamos la columna 'id'
conteos_invitro <- as.data.frame(conteos_invitro)
rownames(conteos_invitro) <- conteos_invitro$id
conteos_invitro$id <- NULL

# MATRIZ DE DISEÑO 
# Extraemos los nombres de las columnas para asignar a qué grupo pertenece cada una
nombres_muestras <- colnames(conteos_invitro)

# Lógica para extraer la Línea (DF.1, DF.1P, DF.1PC) y el Estado (uninfected, IBDV)
metadatos <- data.frame(
  Muestra = nombres_muestras,
  Linea = case_when(
    str_detect(nombres_muestras, "DF\\.1_") ~ "DF.1 (WT)",
    str_detect(nombres_muestras, "DF\\.1P_") ~ "DF.1P (Persistente)",
    str_detect(nombres_muestras, "DF\\.1PC_") ~ "DF.1PC (Curada)"
  ),
  Estado = case_when(
    str_detect(nombres_muestras, "uninfected") ~ "Control",
    str_detect(nombres_muestras, "IBDV") ~ "Infectado"
  )
)

# Creamos un grupo combinado para colorear el gráfico fácilmente
metadatos$Grupo_Combinado <- paste(metadatos$Linea, metadatos$Estado, sep = " - ")

# ==============================================================================
#   PCA 
# ==============================================================================
# Transponemos y aplicamos log2(x + 1) para normalizar la varianza
datos_pca <- log2(t(conteos_invitro) + 1)
pca_res <- prcomp(datos_pca, center = TRUE, scale. = TRUE)

# Calculamos el porcentaje de varianza explicada por cada eje
varianza <- summary(pca_res)$importance[2, ] * 100

# dataframe 
df_pca <- as.data.frame(pca_res$x)
df_pca <- cbind(df_pca, metadatos)

#grafico
grafico_pca_invitro <- ggplot(df_pca, aes(x = PC1, y = PC2, color = Linea, shape = Estado)) +
  geom_point(size = 4, alpha = 0.8) +
  # Usamos una paleta de colores profesional
  scale_color_manual(values = c("DF.1 (WT)" = "#1b9e77", 
                                "DF.1P (Persistente)" = "#d95f02", 
                                "DF.1PC (Curada)" = "#7570b3")) +
  labs(
    x = paste0("Componente Principal 1 (", round(varianza[1], 1), "%)"),
    y = paste0("Componente Principal 2 (", round(varianza[2], 1), "%)"),
    color = "Línea Celular",
    shape = "Condición Viral"
  ) +
  theme_classic(base_family = "sans", base_size = 12) +
  theme(
    legend.position = "right",
    legend.title = element_text(face = "bold"),
    axis.text = element_text(color = "black", size = 11),
    axis.title = element_text(face = "bold", size = 12),
    panel.border = element_rect(colour = "black", fill = NA, linewidth = 1)
  )

print(grafico_pca_invitro)
ggsave("PCA_Invitro_Gallus.png", plot = grafico_pca_invitro, width = 10, height = 7, dpi = 300)


# ==============================================================================
# HEATMAP 
# ==============================================================================
library(pheatmap)
library(RColorBrewer)
library(stringr)

# Asociar los nombres biológicos reales a la matriz completa antes de filtrar
nombres_invitro <- sapply(rownames(conteos_invitro), function(id) {
  nombre_real <- diccionario_gallus$Nombre[diccionario_gallus$ID_GO == id][1]
  if(is.na(nombre_real)) return(id)
  return(nombre_real)
})

# FILTRO SEMÁNTICO: Lista de términos estructurales/genéricos
terminos_basura <- c("cytosol", "nucleus", "cytoplasm", "nucleoplasm", "membrane", 
                     "extracellular", "organelle", "intracellular", "Golgi apparatus", 
                     "mitochondrion", "endoplasmic reticulum", "vesicle", "cytoskeleton",
                     "cell part", "protein binding", "ATP binding", "extracellular region")
                  
patron_filtro <- paste(terminos_basura, collapse = "|")

indices_especificos <- !grepl(patron_filtro, nombres_invitro, ignore.case = TRUE)

conteos_filtrados <- conteos_invitro[indices_especificos, ]
nombres_filtrados <- nombres_invitro[indices_especificos]

# Calcular la varianza y extraer el Top 50 biológicamente relevante
varianzas_go <- apply(conteos_filtrados, 1, var)
indices_top50 <- order(varianzas_go, decreasing = TRUE)[1:50]

matriz_top50 <- conteos_filtrados[indices_top50, ]
nombres_finales <- nombres_filtrados[indices_top50]

# Truncar nombres largos 
nombres_cortos <- str_trunc(nombres_finales, width = 55, side = "right")
rownames(matriz_top50) <- make.unique(as.character(nombres_cortos))

#ordenar
orden_deseado <- c(
  "DF.1_uninfected_S1_R1_001", "DF.1_uninfected_S2_R1_001", "DF.1_uninfected_S3_R1_001",
  "DF.1_IBDV_S1_R1_001", "DF.1_IBDV_S2_R1_001", "DF.1_IBDV_S3_R1_001",
  "DF.1P_uninfected_S1_R1_001", "DF.1P_uninfected_S2_R1_001", "DF.1P_uninfected_S3_R1_001",
  "DF.1P_IBDV_S1_R1_001", "DF.1P_IBDV_S2_R1_001", "DF.1P_IBDV_S3_R1_001",
  "DF.1PC_uninfected_S1_R1_001", "DF.1PC_uninfected_S2_R1_001", "DF.1PC_uninfected_S3_R1_001",
  "DF.1PC_IBDV_S1_R1_001", "DF.1PC_IBDV_S2_R1_001", "DF.1PC_IBDV_S3_R1_001"
)

# Aplicar la transformación logarítmica y ordenar
matriz_log_invitro_ord <- log2(matriz_top50[, orden_deseado] + 1)
anotaciones_col_ord <- anotaciones_columnas[orden_deseado, , drop = FALSE]

# Limpieza visual de los nombres 
colnames(matriz_log_invitro_ord) <- str_replace(colnames(matriz_log_invitro_ord), "_R1_001", "")

# Heatmap 
paleta_divergente <- colorRampPalette(rev(brewer.pal(n = 7, name = "RdBu")))(100)

pheatmap(
  mat = as.matrix(matriz_log_invitro_ord),
  scale = "row",                    
  color = paleta_divergente,
  annotation_col = anotaciones_col_ord,
  annotation_colors = colores_etiquetas,
  cluster_rows = TRUE,              
  cluster_cols = FALSE, # Mantenemos apagado para conservar tu orden de bloques
  show_rownames = TRUE,             
  show_colnames = TRUE,             
  fontsize_row = 8,                 
  fontsize_col = 9,
  angle_col = 45,
  cellwidth = 25,                   
  cellheight = 12,                  
  border_color = "grey90",          
  main = "Perfil Transcriptómico Top 50 Filtrado (Modelo In Vitro)",
  filename = "Heatmap_Invitro_Top50_Filtrado_Perfecto.png"
)


# ==============================================================================
# MODELO DE INTELIGENCIA ARTIFICIAL: RANDOM FOREST
# ==============================================================================
library(randomForest)
library(mixOmics)
library(ggplot2)
library(dplyr)
library(stringr)

#Preparacion de los datos
# X: matriz transcriptómica filtrada (transpuesta para que las muestras sean filas)
X_ml <- as.matrix(t(conteos_filtrados[, orden_deseado]))

# Y: Las etiquetas reales de los 6 grupos experimentales (18 muestras)
Y_ml <- factor(
  c(rep("DF.1_WT_Sana", 3), rep("DF.1_WT_Infectada", 3),
    rep("DF.1P_Sana", 3), rep("DF.1P_Infectada", 3),
    rep("DF.1PC_Curada_Sana", 3), rep("DF.1PC_Curada_Infectada", 3)),
  levels = c("DF.1_WT_Sana", "DF.1_WT_Infectada",
             "DF.1P_Sana", "DF.1P_Infectada",
             "DF.1PC_Curada_Sana", "DF.1PC_Curada_Infectada")
)

cat("\nEntrenando Random Forest (500 árboles)...\n")
set.seed(42) # Semilla de reproducibilidad
modelo_rf <- randomForest(x = X_ml, y = Y_ml, importance = TRUE, ntree = 500)

# Extraer importancia (MeanDecreaseAccuracy)
importancia_rf <- as.data.frame(importance(modelo_rf))
importancia_rf$ID_GO <- rownames(importancia_rf)

# Identificar el Top 20 de biomarcadores
top20_rf <- merge(importancia_rf, diccionario_gallus, by = "ID_GO") %>%
  arrange(desc(MeanDecreaseAccuracy)) %>%
  head(20) %>%
  mutate(Nombre_Corto = str_trunc(Nombre, width = 50, side = "right")) %>%
  arrange(MeanDecreaseAccuracy) %>%
  mutate(Nombre_Corto = factor(Nombre_Corto, levels = Nombre_Corto))

# Gráfico RF
grafico_rf_estetico <- ggplot(top20_rf, aes(x = MeanDecreaseAccuracy, y = Nombre_Corto)) +
  # Usamos el azul oscuro oficial del proyecto con borde negro
  geom_bar(stat = "identity", fill = "#045a8d", color = "black", linewidth = 0.5, width = 0.8) +
  labs(
    x = "Importancia Predictiva (Mean Decrease Accuracy)",
    y = "Proceso Funcional (GO)"
  ) +
  theme_classic(base_family = "sans", base_size = 12) +
  theme(
    axis.text.y = element_text(color = "black", size = 10, face = "bold"),
    axis.text.x = element_text(color = "black", size = 11),
    axis.title = element_text(face = "bold", size = 12),
    panel.border = element_rect(colour = "black", fill = NA, linewidth = 1)
  )

print(grafico_rf_estetico)
ggsave("ML_RandomForest_Invitro_Estetico.png", plot = grafico_rf_estetico, width = 10, height = 7, dpi = 300)


