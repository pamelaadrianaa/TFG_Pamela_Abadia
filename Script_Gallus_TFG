#### RANDOM FOREST: DF.1_uninfected vs DF.1P_IBDV#########
##########################################################
library(randomForest)
library(dplyr)

# 1. Aislamos SOLO las 6 muestras críticas (WT Sana vs Persistente Basal)
muestras_basal <- c("DF.1_uninfected_S1_R1_001", "DF.1_uninfected_S2_R1_001", "DF.1_uninfected_S3_R1_001",
                    "DF.1P_uninfected_S1_R1_001", "DF.1P_uninfected_S2_R1_001", "DF.1P_uninfected_S3_R1_001")

# Filtramos la matriz y transponemos
X_basal <- as.matrix(t(conteos_filtrados[, muestras_basal]))

# Etiquetas estrictas
Y_basal <- factor(c(rep("WT_Sana", 3), rep("Persistente_Basal", 3)))

# 2. Entrenamos el Micro-Random Forest
set.seed(42)
modelo_basal <- randomForest(x = X_basal, y = Y_basal, importance = TRUE, ntree = 500)

# 3. Evaluación del modelo
error_oob_basal <- modelo_basal$err.rate[500, "OOB"]

cat("\n============================================================\n")
cat("RESULTADOS DEL MICRO-MODELO IA (WT SANA vs PERSISTENTE BASAL)\n")
cat("============================================================\n")
cat("Tasa de Error (OOB): ", round(error_oob_basal * 100, 2), "%\n\n", sep="")
cat("Matriz de Confusión:\n")
print(modelo_basal$confusion[, 1:2])

# 4. Si el modelo es capaz de ver la diferencia, extraemos el Top 5 de rutas chivatas
if(error_oob_basal < 0.40) {
  cat("\n¡La IA distingue los estados! Aquí está el Top 5 que delata a la célula persistente:\n")
  imp_basal <- as.data.frame(importance(modelo_basal))
  imp_basal$ID_GO <- rownames(imp_basal)
  
  top_basal <- merge(imp_basal, diccionario_gallus, by = "ID_GO", all.x = TRUE) %>%
    mutate(Nombre_Limpio = ifelse(is.na(Nombre) | Nombre == "", ID_GO, Nombre)) %>%
    arrange(desc(MeanDecreaseAccuracy)) %>%
    head(5) %>%
    dplyr::select(ID_GO, Proceso = Nombre_Limpio, Importancia = MeanDecreaseAccuracy)
  
  print(top_basal)
} else {
  cat("\nLa IA no logra separarlas de forma consistente.\n")
}
