#Función imp_rrf adaptada

imp_rrf_adaptada <- function (formula, data, verbose=T) {
    if (verbose) cat("Construyendo modelo RRF (Regularized Random Forest)...\n")

    # Establecemos una semilla para reproducibilidad
    set.seed(123)

    # El método 'RRF' en caret utiliza regularización para seleccionar variables
    # Este paso puede tardar un poco más que el RF normal
    rrfMod <- caret::train(formula, 
                           data = data, 
                           method = "RRF",
                           importance = TRUE) 

    if (verbose) cat("Calculando importancia de variables...\n")
    rrfImp <- caret::varImp(rrfMod, scale=FALSE)

    # Visualización rápida en consola
    if (verbose) plot(rrfImp, top = 20, main='RRF Variable Importance (Top 20)')

    return(rrfImp$importance)
}

