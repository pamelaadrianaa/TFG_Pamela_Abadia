# Función para calcular la densidad de distancia en el grid
calcular_fondo_distancia <- function(SOM) {
  N <- nrow(SOM$codes[[1]])
  pairwise_dist <- as.matrix(dist(SOM$codes[[1]]))
  
  # Coeficiente de vecindad
  dist_coef <- function(x) { if (x == 0) return(0) else return(1/(x^4)) }
  
  # Distancias geométricas del grid
  grid_dist <- unit.distances(SOM$grid)
  dist_weights <- apply(grid_dist, c(1, 2), dist_coef)
  
  # Calcular suma de distancias escalada
  scaled_dist <- colSums(dist_weights * pairwise_dist)
  return((scaled_dist - min(scaled_dist)) / (max(scaled_dist) - min(scaled_dist)))
}

