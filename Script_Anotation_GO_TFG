##CURVA DE DOSSIS RESPUESTA. 

#demostrará si la activación biológica es proporcional a la carga viral (pfu) o si existe un efecto de saturación a partir de ciertas dosis

# 1. Preparar los datos promediados por dosis y por cluster
cluster_dose_response <- go_exp_calc %>%
  group_by(cluster_ia) %>%
  summarise(
    WT = mean((wt.R1.bam + wt.R2.bam + wt.R3.bam) / 3),
    D0.1 = mean((X0.1pfu.R1.bam + X0.1pfu.R2.bam + X0.1pfu.R3.bam) / 3),
    D1 = mean((X1pfu.R1.bam + X1pfu.R2.bam + X1pfu.R3.bam) / 3),
    D10 = mean((X10pfu.R1.bam + X10pfu.R2.bam + X10pfu.R3.bam) / 3),
    D100 = mean((X100pfu.R1.bam + X100pfu.R2.bam + X100pfu.R3.bam) / 3)
  ) %>%
  # Pasamos a formato largo para ggplot
  pivot_longer(cols = -cluster_ia, names_to = "Dose", values_to = "Expression") %>%
  # Aseguramos el orden de las dosis en el eje X
  mutate(Dose = factor(Dose, levels = c("WT", "D0.1", "D1", "D10", "D100")))

# 2. Graficar la curva de Dosis-Respuesta
ggplot(cluster_dose_response, aes(x = Dose, y = Expression, group = cluster_ia, color = cluster_ia)) +
  geom_line(size = 1.2) +
  geom_point(size = 3) +
  facet_wrap(~cluster_ia, scales = "free_y") + # Cada cluster en su propio panel
  theme_minimal() +
  labs(
    title = "Dinámica de Dosis-Respuesta por Cluster Funcional",
    subtitle = "Promedio de expresión de rutas GO por dosis viral (pfu)",
    x = "Dosis (PFU)",
    y = "Nivel de Expresión Promedio"
  ) +
  theme(legend.position = "none", 
        axis.text.x = element_text(angle = 45, hjust = 1))

#Respuesta Lineal: La expresión sube de forma constante conforme aumenta la dosis (típico de rutas de daño celular).

#Respuesta Umbral (Switch): El cluster se mantiene bajo en WT y 0.1, pero "explota" a partir de 1 o 10 pfu (típico de la respuesta inflamatoria aguda).

#Respuesta de Saturación: Sube rápido en 0.1 y 1 pfu, pero en 10 y 100 se mantiene plano (indica que la célula ya alcanzó su máxima capacidad de respuesta).











