#El LDA (Latent Dirichlet Allocation) es un modelo estadístico y de #inteligencia artificial no supervisada que descubre "temas ocultos" en una #colección de textos, asumiendo que cada documento (como tus descripciones #GO) es una mezcla de diversos temas y que cada tema es una distribución de #palabras. El algoritmo analiza la co-ocurrencia de términos para agrupar #palabras relacionadas semánticamente en categorías biológicas transversales, #permitiéndote sintetizar miles de anotaciones técnicas en unos pocos #conceptos narrativos claros, como "estrés del retículo" o "transporte #viral", basándose en la probabilidad de que ciertas palabras clave aparezcan #juntas.


# 2. Preparar los datos para el modelo
# Creamos una matriz donde cada GO ID es un "documento"
go_counts <- go.sums %>%
  select(id, nam) %>%
  # Tokenizamos la variable 'nam' para extraer palabras clave
  unnest_tokens(word, nam) %>%
  # Limpiamos palabras comunes y genéricas de la nomenclatura GO
  anti_join(stop_words, by = "word") %>%
  filter(!word %in% c("regulation", "process", "cell", "activity", "protein")) %>%
  count(id, word, sort = TRUE)

# Convertir a Document-Term Matrix (DTM)
dtm_go <- go_counts %>%
  cast_dtm(id, word, n)

# 3. Entrenar el modelo LDA
# Ajustamos k (número de tópicos). 6 es un buen punto de partida para 2109 términos.
k_val <- 6
lda_results <- LDA(dtm_go, k = k_val, control = list(seed = 1234))

# 4. Extraer los términos (palabras) más importantes por tópico (Beta)
topics_beta <- tidy(lda_results, matrix = "beta")

# 5. Visualización Interpretable
# Seleccionamos las 10 palabras más probables por cada tópico
top_terms <- topics_beta %>%
  group_by(topic) %>%
  slice_max(beta, n = 10) %>% 
  ungroup() %>%
  arrange(topic, -beta)

# Gráfico de Tópicos
ggplot(top_terms, aes(beta, reorder_within(term, beta, topic), fill = factor(topic))) +
  geom_col(show.legend = FALSE) +
  facet_wrap(~ topic, scales = "free") +
  scale_y_reordered() +
  labs(
    title = "Tópicos Latentes en las Anotaciones GO (Variable 'nam')",
    subtitle = "Cada panel agrupa conceptos biológicos que co-ocurren en tus datos",
    x = "Probabilidad del término en el tópico (Beta)",
    y = NULL
  ) +
  theme_minimal() +
  theme(strip.text = element_text(face = "bold", size = 12))


