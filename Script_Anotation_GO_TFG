#Este es el nivel más avanzado de análisis de texto en Bioinformática. A diferencia de TF-IDF o LDA (que cuentan palabras), los Word Embeddings convierten el lenguaje biológico en vectores numéricos en un espacio multidimensional.

# 2. Extraer los nombres únicos (evitar procesar 2109 si hay duplicados)
go_names <- go.sums %>% 
  select(id, nam) %>% 
  distinct()

# 3. Generar Embeddings (Este paso descarga un modelo ligero de lenguaje)
# Usaremos 'distilbert-base-uncased' por velocidad, pero puedes usar 'dmis-lab/biobert-v1.1'
embeddings <- textEmbed(
  texts = go_names$nam,
  model = "distilbert-base-uncased", # Modelo base (puedes cambiar a BioBERT)
  layers = -2 # Capas profundas para captar semántica
)

# 4. Reducción de dimensionalidad (UMAP)
# Como los embeddings tienen muchas dimensiones (ej. 768), los bajamos a 2 para graficar
umap_results <- umap(embeddings$x, n_neighbors = 15, min_dist = 0.1)

# Preparar dataframe para el plot
plot_data <- data.frame(
  id = go_names$id,
  nam = go_names$nam,
  x = umap_results[,1],
  y = umap_results[,2]
)

# 5. Visualización: Mapa Semántico de Rutas GO
# Resaltamos los nombres más importantes para que sea legible
ggplot(plot_data, aes(x = x, y = y, label = nam)) +
  geom_point(color = "steelblue", alpha = 0.6) +
  # Usamos geom_text_repel para que los nombres no se solapen (requiere ggrepel)
  ggrepel::geom_text_repel(
    data = subset(plot_data, abs(x) > quantile(abs(x), 0.95)), # Solo los extremos
    size = 3,
    max.overlaps = 10
  ) +
  labs(
    title = "Mapa Semántico de Rutas GO (Word Embeddings)",
    subtitle = "Agrupación basada en significado biológico profundo (Contextual NLP)",
    x = "UMAP Dimensión 1",
    y = "UMAP Dimensión 2"
  ) +
  theme_minimal()


