#mira el significado biológico de las descripciones (def) y nombres (nam) de tus términos GO.
#El objetivo es identificar qué palabras son "pesadas" o distintivas en tu set de datos, ayudándote a definir la "firma temática" de tu experimento (por ejemplo, si aparecen muchas palabras relacionadas con "autofagia" o "respuesta viral").


# 2. Procesar los datos
# Vamos a tratar cada 'id' como un documento y su 'def' como el contenido
go_tfidf_analysis <- go.sums %>%
  select(id, def) %>%
  # Tokenizamos la definición: separamos por palabras
  unnest_tokens(word, def) %>%
  # Limpieza de "stop words" y palabras genéricas de GO que no aportan
  anti_join(stop_words, by = "word") %>%
  filter(!word %in% c("process", "cell", "protein", "activity", "results")) %>%
  # Contamos palabras por ID
  count(id, word, sort = TRUE) %>%
  # Calculamos el TF-IDF basado en el ID
  bind_tf_idf(word, id, n)

# 3. Identificar los términos más importantes
# Agrupamos por ID para obtener la relevancia semántica total de cada término GO
go_importance <- go_tfidf_analysis %>%
  group_by(id) %>%
  summarise(relevance_score = sum(tf_idf)) %>%
  arrange(desc(relevance_score)) %>%
  # Unimos de vuelta con la definición original para el gráfico
  left_join(unique(go.sums[, c("id", "def")]), by = "id") %>%
  # Tomamos los 15 más importantes para que el plot sea legible
  slice_max(relevance_score, n = 15)

# 4. Crear el Plot Interpretable
ggplot(go_importance, aes(x = reorder(def, relevance_score), y = relevance_score)) +
  geom_col(aes(fill = relevance_score), show.legend = FALSE) +
  # Función para que las definiciones largas se dividan en varias líneas
  scale_x_discrete(labels = function(x) str_wrap(x, width = 50)) +
  coord_flip() +
  scale_fill_gradient(low = "lightblue", high = "darkblue") +
  labs(
    title = "Top 15 Rutas GO más Representativas",
    subtitle = "Ranking basado en importancia semántica (TF-IDF)",
    x = "Definición de la Ruta (Análisis de Texto)",
    y = "Puntaje de Relevancia"
  ) +
  theme_minimal()
  
  
#Precisión por ID: Al agrupar por id, el modelo TF-IDF entiende que cada #código de Gene Ontology es una unidad de información distinta, evitando #confusiones si dos términos diferentes usaran palabras similares.

#Legibilidad Humana: Al usar str_wrap y mapear el eje X a def, el gráfico se #explica solo. Cualquiera que lo vea entenderá que la ruta importante es "Any #process that results in a change..." en lugar de tener que buscar qué #significa "GO:000XXXX".

#Filtrado de Ruido: He añadido un filtro manual (filter(!word %in% c(...))) #para quitar palabras como "process" o "activity". En Bioinformática, estas #palabras aparecen en casi todas las definiciones GO y suelen "inflar" el #puntaje sin aportar valor biológico real. 
  
