#El Análisis de Sentimiento Biológico es una técnica de minería de texto que #clasifica tus rutas GO según su "propósito" funcional mediante el uso de un #diccionario de palabras clave predefinido. En lugar de medir emociones, este #método asigna una puntuación de polaridad a cada término basándose en #conceptos contrapuestos, como Respuesta Defensiva (inflamación, apoptosis, #estrés) frente a Homeostasis (metabolismo, biosíntesis, ciclo celular). Al #cruzar esta puntuación con tus clusters, puedes determinar cuantitativamente #si un grupo funcional está orientado a la lucha contra la infección o al #mantenimiento celular, permitiéndote narrar tus resultados de RNA-seq no #solo en términos de genes, sino de estrategias biológicas globales adoptadas #por la célula ante el estímulo viral.

# 1. Ejecutar el análisis de sentimiento con la corrección de 'drop = FALSE'
go_sentiment <- go.sums %>%
  left_join(df_clusters, by = "id") %>% 
  select(id, nam, cluster_ia) %>%
  distinct() %>%
  # drop = FALSE mantiene la columna 'nam' después de separar las palabras
  unnest_tokens(word, nam, drop = FALSE) %>% 
  inner_join(bio_lexicon, by = "word") %>%
  count(id, nam, cluster_ia, sentiment) %>%
  pivot_wider(names_from = sentiment, values_from = n, values_fill = 0) %>%
  # Aseguramos que existan ambas columnas para que la resta no falle
  mutate(
    defensive = if("defensive" %in% names(.)) defensive else 0,
    homeostasis = if("homeostasis" %in% names(.)) homeostasis else 0,
    polarity_score = defensive - homeostasis
  )

# 2. Generar el gráfico de cajas (Boxplot)
library(ggplot2)
ggplot(go_sentiment, aes(x = cluster_ia, y = polarity_score, fill = cluster_ia)) +
  geom_boxplot(alpha = 0.7, outlier.shape = NA) +
  geom_jitter(width = 0.2, alpha = 0.3, size = 1) +
  geom_hline(yintercept = 0, linetype = "dashed", color = "red", size = 1) +
  labs(
    title = "Perfil de Sentimiento Biológico por Cluster",
    subtitle = "Valores > 0: Defensa/Estrés | Valores < 0: Homeostasis/Metabolismo",
    x = "Cluster (Agrupamiento Semántico)",
    y = "Índice de Polaridad"
  ) +
  theme_minimal() +
  theme(legend.position = "none")
  
  
