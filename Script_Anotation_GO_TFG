get.biomart.goslim.annotation <- function(mart.db, folder) {
    
    file.path <- paste(folder, "/biomart.goslim.tab", sep="")
    
    if (!file.exists(file.path)) {
        bm.goslim.annot <- getBM(
            attributes=c(
                "ensembl_gene_id", 
                "goslim_goa_accession", 
                "goslim_goa_description"
                ),
            mart=mart.db)
        
        write.table(bm.goslim.annot, file.path, 
                    row.names=TRUE, col.names=TRUE, sep="\t")
        
    } else {
        bm.goslim.annot <- read.table(file.path, header=TRUE, sep="\t")
    }
    
    return(bm.goslim.annot)
}


