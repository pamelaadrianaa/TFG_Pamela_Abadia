nrow(matrix_nmf)  #[1] 2109

# Importante: El NMF no acepta valores de 0 en toda una fila
matrix_nmf <- matrix_nmf[rowSums(matrix_nmf) > 0, ]


##2. Rango de factorización.
#Elegir el valor k (número de firmas o factores). 
# Este paso busca el rango óptimo (k). Probamos de 2 a 6 firmas.
# nrun=10 es para una prueba rápida, en un análisis real usa 50 o 100.
estimate_k <- nmf(matrix_nmf, 2:6, nrun = 10, seed = 123456)
plot(estimate_k)  #visualización

#Tip: Busca el punto donde el Coeficiente de 
#Correlación Cophenetic empieza a caer bruscamente. 
#Ese suele ser el $k$ ideal.
#Elegimos k=5 

##3. Ejecución del NMF: 

k_chosen <- 5
res_nmf <- nmf(matrix_nmf, rank = k_chosen, method = "brunet", seed = 123456)

# Extraer las matrices W y H
# W: Relación entre GO terms y Firmas (Basis matrix)
# H: Relación entre Firmas y Muestras (Coefficient matrix)
W <- basis(res_nmf)
H <- coef(res_nmf)
     
     
###INTERPRETACIÓN DE LOS RESULTADOS

# 1. Mapa de calor de las muestras (Matriz H)
# Esto mostrará qué firma domina en cada experimento/réplica
