#técnica de Similitud de Coseno sobre una matriz de términos (basada en el método TF-IDF). Esto agrupa los términos GO comparando cuántas palabras biológicas comparten en sus nombres


# 1. Cargar librerías
library(tidyverse)
library(tidytext)
library(proxy)    # Para calcular distancias de similitud
library(pheatmap) # Para el gráfico final

# 2. Crear una matriz de "palabras por ID"
# Esto convierte tus 2109 nombres en una matriz numérica que R entiende
go_matrix_data <- go.sums %>%
  select(id, nam) %>%
  distinct() %>%
  unnest_tokens(word, nam) %>%
  anti_join(stop_words) %>%
  # Contamos palabras por cada ID
  count(id, word) %>%
  # Convertimos a formato de matriz ancha (sparse matrix)
  cast_sparse(id, word, n)

# 3. Calcular la Distancia de Coseno
# En lugar de embeddings, medimos qué tanto se solapan las palabras de los nombres
# convertimos a matriz normal para el cálculo
dist_matrix <- proxy::dist(as.matrix(go_matrix_data), method = "cosine")

# 4. Clustering Jerárquico
# Usamos el método de Ward para crear grupos compactos
hc_model <- hclust(dist_matrix, method = "ward.D2")

# 5. Cortar el árbol en Clusters (ejemplo: 12 grupos)
num_clusters <- 12
clusters <- cutree(hc_model, k = num_clusters)

# 6. Unir los resultados con tus datos originales
# Creamos un dataframe con el ID y su cluster correspondiente
df_clusters <- data.frame(
  id = rownames(as.matrix(go_matrix_data)), 
  cluster_ia = as.factor(clusters)
)

go_resultados_final <- go.sums %>%
  left_join(df_clusters, by = "id")

# 7. Visualización: ¿Qué hay en cada cluster?
# Vamos a ver los nombres de los primeros 5 términos del Cluster 1
print("Muestra del Cluster 1:")
go_resultados_final %>%
  filter(cluster_ia == 1) %>%
  select(nam) %>%
  distinct() %>%
  head(10)

