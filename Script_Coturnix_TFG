library(tidyverse)
library(ggplot2)
 
# Preparación de los datos: partimos de 'datos_conteos' que ya tienes en tu script.
# Transformamos a logaritmo para estabilizar la varianza matemática
log_counts <- log2(datos_conteos + 1)
 
# Calculamos la media de expresión de las 3 réplicas para cada dosis
# Las columnas del 1 al 15 corresponden a: WT, 0.1, 1, 10, 100 PFU (3 réplicas cada una)
 medias_por_dosis <- data.frame(
    +     "Control_0PFU" = rowMeans(log_counts[, 1:3]),
    +     "Dosis_0.1PFU" = rowMeans(log_counts[, 4:6]),
    +     "Dosis_1PFU"   = rowMeans(log_counts[, 7:9]),
    +     "Dosis_10PFU"  = rowMeans(log_counts[, 10:12]),
    +     "Dosis_100PFU" = rowMeans(log_counts[, 13:15])
    + )

 # 3. Escalar los datos (Z-score por fila)
 # CRÍTICO: Esto hace que rutas con muchos o pocos conteos se puedan comparar por su "tendencia"
 datos_escalados <- t(scale(t(medias_por_dosis)))
datos_escalados <- na.omit(datos_escalados) # Eliminamos filas con varianza 0 por seguridad

# Clustering (K-Means)
 set.seed(123) # Fijamos semilla para que siempre te salgan los mismos clusters
num_clusters <- 6 # Vamos a agrupar todas las rutas de la Ontología Génica en 6 patrones
 km_res <- kmeans(datos_escalados, centers = num_clusters, nstart = 25)

 # Añadimos el clúster asignado a  tabla de datos
 datos_plot <- as.data.frame(datos_escalados)
 datos_plot$Cluster <- paste("Patrón", km_res$cluster)
 datos_plot$GO_ID <- rownames(datos_plot)
 
 # Transformar a formato largo para ggplot2 (Tidy Data)
 datos_largos <- datos_plot %>%
  +     pivot_longer(cols = starts_with("Dosis") | starts_with("Control"), 
                     +                  names_to = "Dosis", 
                     +                  values_to = "Z_score") %>%
  +     # Forzamos el orden cronológico/cuantitativo en el eje X
  +     mutate(Dosis = factor(Dosis, levels = c("Control_0PFU", "Dosis_0.1PFU", "Dosis_1PFU", "Dosis_10PFU", "Dosis_100PFU")))

 #  Visualización de los Clústeres (Trend Plot)
plot_tendencias <- ggplot(datos_largos, aes(x = Dosis, y = Z_score, group = GO_ID)) +
  +     # Dibujamos las líneas individuales de cada ruta funcional muy tenues de fondo
  +     geom_line(alpha = 0.05, color = "black") + 
  +     # Superponemos la línea roja gruesa que marca la tendencia media de ese clúster
  +     stat_summary(aes(group = 1), fun = mean, geom = "line", linewidth = 1.5, color = "#de2d26") + 
  +     facet_wrap(~ Cluster, scales = "fixed") + # Separar en 6 paneles
  +     theme_minimal(base_size = 14) +
  +     labs(
    +         title = "Dinámica Transcriptómica Dosis-Respuesta (Coturnix japonica)",
    +         subtitle = "Agrupamiento funcional (K-Means) de rutas según su comportamiento frente a la carga vírica",
    +         x = "Carga Vírica (IBDV)",
    +         y = "Nivel de Expresión Estandarizado (Z-score)"
    +     ) +
  +     theme(
    +         axis.text.x = element_text(angle = 45, hjust = 1, face = "bold"),
    +         strip.text = element_text(face = "bold", size = 12, color = "white"),
    +         strip.background = element_rect(fill = "#3182bd", color = NA),
    +         panel.grid.minor = element_blank()
    +     )


 print(plot_tendencias)
 
 ggsave("Clusters_Tendencia_Coturnix.png", plot = plot_tendencias, width = 12, height = 8, dpi = 300)




