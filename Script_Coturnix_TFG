# MODELO ESTADISTICO CLASICO: DESeq2
# ==============================================================================

library(DESeq2)
library(ggplot2)
library(ggrepel)
library(dplyr)
library(stringr)

# Preparación de la Matriz para DESeq2 (Exige números enteros)
conteos_deseq <- round(datos_go[, 3:17])
rownames(conteos_deseq) <- rownames(datos_go)

# Reconstruimos la matriz de diseño original asegurando que WT sea el nivel de referencia (Control)
diseno_deseq <- data.frame(
  Condicion = factor(
    c(rep("wt", 3), rep("0.1_pfu", 3), rep("1_pfu", 3), rep("10_pfu", 3), rep("100_pfu", 3)),
    levels = c("wt", "0.1_pfu", "1_pfu", "10_pfu", "100_pfu")
  )
)
# Es obligatorio que las filas del diseño se llamen igual que las columnas de los conteos
rownames(diseno_deseq) <- colnames(conteos_deseq)

# Creación del Objeto DESeq2 y ejecución del algoritmo
cat("Ejecutando modelo estadístico DESeq2 (puede tardar unos segundos)...\n")
dds <- DESeqDataSetFromMatrix(countData = conteos_deseq,
                              colData = diseno_deseq,
                              design = ~ Condicion)

# Ejecutamos el pipeline completo de DESeq2 (estimación de tamaño, dispersión y test Wald)
dds <- DESeq(dds)

# Resultados: 100 PFU vs WT
res_100_vs_wt <- results(dds, contrast = c("Condicion", "100_pfu", "wt"))
res_df <- as.data.frame(res_100_vs_wt)

# Añadimos los IDs 
res_df$ID_GO <- rownames(res_df)
res_df <- merge(res_df, diccionario_go[, c("ID_GO", "Nombre")], by = "ID_GO", all.x = TRUE)

# Limpiamos los NA 
res_df <- na.omit(res_df)


### EXTRACCIÓN DE TABLAS DESEQ2

library(dplyr)
library(readr) 

# Filtrar el dataframe para quedarnos solo con lo estadísticamente significativo
rutas_significativas <- res_df %>% filter(Regulacion != "No Significativo")

# Extraer el Top 20 de rutas SOBREEXPRESADAS 
top_up <- rutas_significativas %>%
  filter(Regulacion == "Sobreexpresado (Up)") %>%
  arrange(desc(log2FoldChange)) %>%
  head(20) %>%
  dplyr::select(ID_GO, Nombre, log2FoldChange, padj) # CRÍTICO: Forzamos el select de dplyr

#  Extraer el Top 20 de rutas INFRAEXPRESADAS 
top_down <- rutas_significativas %>%
  filter(Regulacion == "Infraexpresado (Down)") %>%
  arrange(log2FoldChange) %>%
  head(20) %>%
  dplyr::select(ID_GO, Nombre, log2FoldChange, padj) # CRÍTICO: Forzamos el select de dplyr

#  Mostrar 
cat("\n============================================================\n")
cat("TOP 10 RUTAS SOBREEXPRESADAS (RESPUESTA MASIVA AL IBDV)\n")
cat("============================================================\n")
print(head(top_up, 10))

cat("\n============================================================\n")
cat("TOP 10 RUTAS INFRAEXPRESADAS (APAGÓN CELULAR INDUCIDO)\n")
