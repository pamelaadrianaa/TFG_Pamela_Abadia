library(caret)
library(randomForest)
library(ggplot2)
library(dplyr)
library(stringr)

#Preparación de los datos
# Usaremos 'datos_filtrados' (Heatmap) para mantener fuera el ruido anatómico
datos_rf <- as.data.frame(t(datos_filtrados))

# Definimos la variable objetivo (Target) como FACTOR (Clasificación para extraer Gini)
grupos <- factor(c(rep("WT", 3), rep("0.1_PFU", 3), rep("1_PFU", 3), rep("10_PFU", 3), rep("100_PFU", 3)),
                 levels = c("WT", "0.1_PFU", "1_PFU", "10_PFU", "100_PFU"))
datos_rf$Target <- grupos

colnames(datos_rf) <- make.names(colnames(datos_rf))

# Entrenamiento del Modelo (LOOCV)
cat("Entrenando Random Forest con validación LOOCV (esto puede tardar unos segundos)...\n")
set.seed(42) # Semilla matemática para que el resultado sea reproducible en tu TFG

control_rf <- trainControl(method = "LOOCV")

# Entrenamos el modelo asegurando que calcule la importancia (Gini)
modelo_rf <- train(
  Target ~ .,
  data = datos_rf,
  method = "rf",
  trControl = control_rf,
  importance = TRUE,     # CRÍTICO: Ordena al algoritmo calcular la Importancia de Gini
  ntree = 500            # Construimos 500 árboles de decisión
)

# Imprimimos la precisión matemática (Accuracy) lograda durante la validación cruzada
precision <- max(modelo_rf$results$Accuracy) * 100
cat("✓ Modelo entrenado. Precisión predictiva global:", round(precision, 2), "%\n")

# Extracción de la Importancia de Gini
matriz_importancia <- as.data.frame(modelo_rf$finalModel$importance)
matriz_importancia$ID_GO_Temp <- rownames(matriz_importancia)

# Seleccionamos solo la métrica MeanDecreaseGini y cogemos el Top 20
top_biomarcadores <- matriz_importancia %>%
  select(ID_GO_Temp, MeanDecreaseGini) %>%
  arrange(desc(MeanDecreaseGini)) %>%
  head(20)

top_biomarcadores$ID_GO <- gsub("\\.", ":", top_biomarcadores$ID_GO_Temp)

#Damos nombre a los resultados
diccionario <- datos_go[, c("nam", "def")]
diccionario$ID_GO <- rownames(datos_go)

resultados_rf <- merge(top_biomarcadores, diccionario, by = "ID_GO") %>%
  arrange(desc(MeanDecreaseGini))

# Acortamos los nombres muy largos 
resultados_rf$Nombre_Corto <- str_trunc(resultados_rf$nam, width = 55, side = "right")

resultados_rf$Nombre_Corto <- factor(resultados_rf$Nombre_Corto, levels = rev(resultados_rf$Nombre_Corto))

# Gráfico de Biomarcadores 
grafico_rf <- ggplot(resultados_rf, aes(x = MeanDecreaseGini, y = Nombre_Corto, fill = MeanDecreaseGini)) +
  geom_bar(stat = "identity", color = "black", size = 0.3) +
  scale_fill_gradient(low = "#a6bddb", high = "#045a8d") +
  labs(
    x = "Disminución Media de Gini (Peso del Biomarcador)",
    y = "Proceso / Función Biológica",
    fill = "Gini"
  ) +
  theme_classic(base_family = "sans", base_size = 12) +
  theme(
    axis.text.y = element_text(color = "black", size = 10, face = "bold"),
    axis.text.x = element_text(color = "black", size = 11),
    axis.title = element_text(face = "bold", size = 12),
    legend.position = "none", # Ocultamos la leyenda porque el eje X ya da la información numérica
    panel.border = element_rect(colour = "black", fill = NA, size = 1)
  )

print(grafico_rf)
ggsave("RandomForest_Top20_Gini_AltaCalidad.png", plot = grafico_rf, width = 10, height = 7, dpi = 300)


