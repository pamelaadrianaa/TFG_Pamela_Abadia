# Analisis de componentes principales (PCA)
#Preparar la matriz numérica (aislamos las 15 columnas de conteos)
datos_numericos <- datos_go[, 3:17]
datos_pca <- as.data.frame(t(datos_numericos)) #transponemos

varianza_columnas <- apply(datos_pca, 2, var)
datos_pca_limpios <- datos_pca[, varianza_columnas > 0] #limpieza por seguridad 

pca_resultado <- prcomp(datos_pca_limpios, center = TRUE, scale. = TRUE) #PCA

# Extraer los porcentajes de varianza para los ejes
varianza_explicada <- summary(pca_resultado)$importance[2, ]
pc1_var <- round(varianza_explicada[1] * 100, 1)
pc2_var <- round(varianza_explicada[2] * 100, 1)

#Integración con la matriz de Diseño Experimental
# Cruzamos las coordenadas (x, y) de cada punto con los grupos biológicos
datos_grafico <- data.frame(
  Muestra = rownames(pca_resultado$x),
  PC1 = pca_resultado$x[, 1],
  PC2 = pca_resultado$x[, 2],
  Condicion = diseno$Condicion,
