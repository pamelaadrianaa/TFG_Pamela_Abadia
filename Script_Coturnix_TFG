# ==============================================================================
# MODELO ESTADISTICO CLASICO: edgeR (WT vs 100 PFU)
# ==============================================================================

library(edgeR)
library(dplyr)
library(readr)

# Preparación de Datos 
grupos_edger <- factor(
  c(rep("WT", 3), rep("0.1_PFU", 3), rep("1_PFU", 3), rep("10_PFU", 3), rep("100_PFU", 3)),
  levels = c("WT", "0.1_PFU", "1_PFU", "10_PFU", "100_PFU")
)

# Creación del objeto DGEList 
y <- DGEList(counts = conteos_deseq, group = grupos_edger)

cat("Ejecutando pipeline de edgeR...\n")

# Normalización TMM (Trimmed Mean of M-values)
#elimina sesgos de composición en el RNA-seq
y <- calcNormFactors(y)

# Estimación de Dispersión (Ajuste del modelo binomial negativo)
y <- estimateDisp(y)

# Analisis WT vs 100 PFU
# edgeR compara el segundo elemento respecto al primero
test_exacto <- exactTest(y, pair = c("WT", "100_PFU"))

# Resultados
# tabla completa de resultados ordenados por p-valor
resultados_edger <- topTags(test_exacto, n = Inf)$table

# Añadimos la columna de IDs 
resultados_edger$ID_GO <- rownames(resultados_edger)
resultados_edger <- merge(resultados_edger, diccionario_go[, c("ID_GO", "Nombre")], by = "ID_GO", all.x = TRUE)

# edgeR llama al p-valor ajustado "FDR" (False Discovery Rate), y al Fold Change "logFC"
# Filtramos para quedarnos solo con lo significativo (FDR < 0.05 y logFC extremo)
rutas_significativas_edger <- resultados_edger %>%
  filter(FDR < 0.05) %>%
  mutate(
    Regulacion = case_when(
      logFC > 1 ~ "Sobreexpresado (Up)",
      logFC < -1 ~ "Infraexpresado (Down)",
      TRUE ~ "No Significativo"
    )
  ) %>%
  filter(Regulacion != "No Significativo")

# Mostramos el Top 5 para comparar con DESeq2
cat("\n============================================================\n")
cat("TOP 5 RUTAS SOBREEXPRESADAS (edgeR)\n")
cat("============================================================\n")
print(
  rutas_significativas_edger %>% 
    filter(Regulacion == "Sobreexpresado (Up)") %>% 
    arrange(desc(logFC)) %>% 
    head(5) %>% 
    dplyr::select(ID_GO, Nombre, logFC, FDR)
)

# Exportamos tabla 
write_csv(rutas_significativas_edger, "Tabla_Completa_Significativos_edgeR_100PFU.csv")


