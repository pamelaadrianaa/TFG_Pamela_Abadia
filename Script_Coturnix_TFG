library(pheatmap)
library(RColorBrewer)
library(stringr)

# 1. Extraer los datos numéricos y los nombres
datos_numericos <- datos_go[, 3:17]
nombres_go <- datos_go$nam

# 2. FILTRO SEMÁNTICO: Lista negra de términos estructurales/genéricos (Componentes Celulares)
terminos_basura <- c("cytosol", "nucleus", "cytoplasm", "nucleoplasm", "membrane", 
                     "extracellular", "organelle", "intracellular", "Golgi apparatus", 
                     "mitochondrion", "endoplasmic reticulum", "vesicle", "cytoskeleton",
                     "cell part", "protein binding", "ATP binding")

# Creamos un patrón de búsqueda 
patron_filtro <- paste(terminos_basura, collapse = "|")

# Nos quedamos SOLO con las rutas que NO contienen esas palabras genéricas
indices_especificos <- !grepl(patron_filtro, nombres_go, ignore.case = TRUE)

datos_filtrados <- datos_numericos[indices_especificos, ]
nombres_filtrados <- nombres_go[indices_especificos]

#Se han eliminado las rutas estructurales masivas

# Calcular la varianza 
varianzas_go <- apply(datos_filtrados, 1, var)

# Seleccionar el Top 50 real
indices_top50 <- order(varianzas_go, decreasing = TRUE)[1:50]
matriz_top50 <- datos_filtrados[indices_top50, ]

# Sustituir IDs por los nombres biológicos
nombres_finales <- nombres_filtrados[indices_top50]
nombres_finales[is.na(nombres_finales) | nombres_finales == ""] <- rownames(matriz_top50)[is.na(nombres_finales) | nombres_finales == ""]

# Truncar nombres excesivamente largos (máximo 55 caracteres)
nombres_cortos <- str_trunc(nombres_finales, width = 55, side = "right")
rownames(matriz_top50) <- make.unique(as.character(nombres_cortos))

# Limpieza de las etiquetas de las columnas
nombres_columnas <- colnames(matriz_top50)
nombres_columnas <- str_replace(nombres_columnas, "^X", "")       
nombres_columnas <- str_replace(nombres_columnas, "\\.bam$", "")  
nombres_columnas <- str_replace_all(nombres_columnas, "\\.", "_") 
nombres_columnas <- str_replace(nombres_columnas, "wt", "WT")
colnames(matriz_top50) <- nombres_columnas

anotacion_col <- data.frame(
  `Carga Vírica` = c(rep("Control (WT)", 3), rep("0.1 PFU", 3), rep("1 PFU", 3), rep("10 PFU", 3), rep("100 PFU", 3)),
  check.names = FALSE 
)
rownames(anotacion_col) <- nombres_columnas

colores_anotacion <- list(
  `Carga Vírica` = c("Control (WT)" = "#4daf4a", "0.1 PFU" = "#a6bddb", 
                     "1 PFU" = "#74a9cf", "10 PFU" = "#2b8cbe", "100 PFU" = "#045a8d")
)

paleta_divergente <- colorRampPalette(rev(brewer.pal(n = 7, name = "RdBu")))(100)

pheatmap(
  mat = as.matrix(matriz_top50),
  scale = "row",                    
  color = paleta_divergente,
  annotation_col = anotacion_col,
  annotation_colors = colores_anotacion,
  cluster_rows = TRUE,              
  cluster_cols = TRUE,              
  show_rownames = TRUE,             
  show_colnames = TRUE,             
  fontsize_row = 8,                 # Letra un poco más grande y legible
  fontsize_col = 10,
  angle_col = 45,
  
  # Forzar las dimensiones exactas de cada celda en puntos
  cellwidth = 25,                   # Cuadraditos más anchos
  cellheight = 12,                  # Cuadraditos suficientemente altos para que respire la letra
  border_color = "grey90",          # Un borde muy sutil gris claro para separar las celdas visualmente
  
  # Eliminamos width y height globales para que R calcule el tamaño ideal del lienzo
  filename = "Heatmap_Top50_Proporciones_Perfectas.png"
)




