#Librerias
library(tidyverse)
library(caret)
library(glmnet)
library(ggplot2)
library(ggrepel)



# 1. Cargar nuestros datos
datos_go <- read.csv("go_sums_coturnix_japonica.csv", row.names = 1)

dim(datos_go) #observación

go_anotaciones <- datos_go[, c("nam", "def")]
datos_conteos <- datos_go[, 3:17] # Solo las 15 columnas de las muestras (.bam)

# 2. Definir matriz diseño 
#Tres replicas por cada condicion
nombres_muestras <- colnames(datos_go)[3:17]
grupos_categoricos <- c(
  rep("wt", 3), 
  rep("0.1_pfu", 3), 
  rep("1_pfu", 3), 
  rep("10_pfu", 3), 
  rep("100_pfu", 3)
)
#definir la dosis
dosis_numericas <- c(
  rep(0, 3), 
  rep(0.1, 3), 
  rep(1, 3), 
  rep(10, 3), 
  rep(100, 3)
)
diseno <- data.frame(
  Muestra = nombres_muestras,
  Condicion = factor(grupos_categoricos, levels = c("wt", "0.1_pfu", "1_pfu", "10_pfu", "100_pfu")),
  Dosis = dosis_numericas
)
# Asignar los nombres de las muestras a los nombres de fila del diseño (para DESeq2)
rownames(diseno) <- diseno$Muestra

print(diseno)

