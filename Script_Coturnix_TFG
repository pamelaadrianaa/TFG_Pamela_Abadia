# ==============================================================================

library(mixOmics)
library(ggplot2)
library(dplyr)
library(stringr)

# 1. Preparación Estricta de Matrices (X e Y)
X <- as.matrix(t(datos_filtrados)) 

# Y: Variable respuesta (Categorías de dosis de IBDV)
Y <- factor(c(rep("Control (WT)", 3), rep("0.1 PFU", 3), rep("1 PFU", 3), rep("10 PFU", 3), rep("100 PFU", 3)),
            levels = c("Control (WT)", "0.1 PFU", "1 PFU", "10 PFU", "100 PFU"))

# 2. Entrenamiento del Modelo sPLS-DA
cat("Entrenando sPLS-DA...\n")
# ncomp = 2 (Queremos 2 componentes principales supervisados)
# keepX = c(20, 20) (Le obligamos a seleccionar SÓLO las 20 rutas más cruciales por componente)
modelo_splsda <- splsda(X, Y, ncomp = 2, keepX = c(20, 20))


### VISUALIZACIÓN 1: SEGREGACIÓN DE MUESTRAS (Supervised PCA)

# Extraemos las coordenadas matemáticas del modelo
coordenadas_muestras <- as.data.frame(modelo_splsda$variates$X)
coordenadas_muestras$Grupo <- Y

# Calculamos el % de varianza explicada por cada componente para los ejes
var_exp <- modelo_splsda$prop_expl_var$X
eje_x_lbl <- paste0("Componente 1 (", round(var_exp[1] * 100, 1), "%)")
eje_y_lbl <- paste0("Componente 2 (", round(var_exp[2] * 100, 1), "%)")

grafico_splsda_muestras <- ggplot(coordenadas_muestras, aes(x = comp1, y = comp2, color = Grupo)) +
  stat_ellipse(geom = "polygon", aes(fill = Grupo), alpha = 0.15, linetype = "dashed", size = 0.5) +
  geom_point(size = 4, alpha = 0.9) +
  scale_color_manual(values = c("Control (WT)" = "#4daf4a", "0.1 PFU" = "#a6bddb", 
                                "1 PFU" = "#74a9cf", "10 PFU" = "#2b8cbe", "100 PFU" = "#045a8d")) +
  scale_fill_manual(values = c("Control (WT)" = "#4daf4a", "0.1 PFU" = "#a6bddb", 
                               "1 PFU" = "#74a9cf", "10 PFU" = "#2b8cbe", "100 PFU" = "#045a8d")) +
  labs(x = eje_x_lbl, y = eje_y_lbl, color = "Carga Vírica", fill = "Carga Vírica") +
  theme_classic(base_family = "sans", base_size = 12) +
  theme(
    legend.position = "right",
    legend.title = element_text(face = "bold"),
    legend.background = element_rect(color = "black", size = 0.3),
    axis.text = element_text(color = "black", size = 11),
    axis.title = element_text(face = "bold", size = 12),
    panel.border = element_rect(colour = "black", fill = NA, size = 1)
  )

print(grafico_splsda_muestras)



### VISUALIZACIÓN 2: LOS BIOMARCADORES (Loadings del Componente 1)

